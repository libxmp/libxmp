ALL_OBJS	= $(OBJS)
ifeq ($(USE_PROWIZARD),1)
ALL_OBJS += $(PROWIZ_OBJS)
endif
ifeq ($(USE_DEPACKERS),1)
ALL_OBJS += $(DEPACKER_OBJS)
endif
TEST_OBJS = test/md5.o test/test.o
TESTLITE_OBJS = test/md5.o test/testlite.o

.PHONY: clean distclean

all: $(DLLFILE) xmp_dll.a xmp.lib xmp.a
lite: $(DLLLITE) xmp-lite_dll.a xmp-lite.lib xmp-lite.a

.c.o:
	$(CC) $(CFLAGS) -c -o $@ $<

test/md5.o: src/md5.c
	$(CC) $(CFLAGS) -c -o $@ $<
test/test.o: test/test.c
	$(CC) $(CFLAGS) -c -o $@ $<
test/testlite.o: test/testlite.c
	$(CC) $(CFLAGS) -c -o $@ $<

$(DLLFILE): $(ALL_OBJS) $(DEFNAME)
	$(CC) $(LDFLAGS) -o $(DLLFILE) $(DEFNAME) $(ALL_OBJS)
$(DLLLITE): $(LITE_OBJS) $(DEFLITE)
	$(CC) $(LDFLAGS) -o $(DLLLITE) $(DEFLITE) $(LITE_OBJS)

xmp.a: $(ALL_OBJS)
	$(AR) cru xmp.a $(ALL_OBJS)
	$(RANLIB) xmp.a
xmp-lite.a: $(LITE_OBJS)
	$(AR) cru xmp-lite.a $(LITE_OBJS)
	$(RANLIB) xmp-lite.a

xmp_dll.a: $(DLLFILE)
	emximp -o $@ $(DLLFILE)
xmp-lite_dll.a: $(DLLLITE)
	emximp -o $@ $(DLLLITE)

xmp.lib: xmp_dll.a
	emxomf -o $@ $<
xmp-lite.lib: xmp-lite_dll.a
	emxomf -o $@ $<

test/$(TESTNAME): $(LIBFILE) $(TEST_OBJS)
	$(CC) $(TEST_OBJS) -L. -lxmp -Zmt -o $@
test/$(TESTLITE): $(LIBLITE) $(TESTLITE_OBJS)
	$(CC) $(TESTLITE_OBJS) -L. -lxmp-lite -Zmt -o $@
check: test/$(TESTNAME)
	cd test & $(TESTNAME)
check-lite: test/$(TESTLITE)
	cd test & $(TESTLITE)

clean:
	$(RM) src/*.o
	$(RM) src/loaders/*.o
	$(RM) src/lite/*.o
	$(RM) src/loaders/prowizard/*.o
	$(RM) src/depackers/*.o
	$(RM) test/*.o
distclean: clean
	$(RM) *.dll *.a *.lib
	$(RM) test/*.exe
