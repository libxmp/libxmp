# GNU Makefile for OS/2 -- using GCC/EMX KLIBC environment
#	make -f Makefile.emx
#
# To disable module depacker functionality:
#	make -f Makefile.emx USE_DEPACKERS=0
#
# To disable ProWizard functionality:
#	make -f Makefile.emx USE_PROWIZARD=0
#
# To build the lite version of the library:
#	make -f Makefile.emx lite
#
# To cross-compile on linux, specify cross-compiler prefix,
# e.g.:
#	make -f Makefile.emx CROSS=i686-pc-os2-emx

USE_DEPACKERS	= 1
USE_PROWIZARD	= 1

DLLFILE = libxmp.dll
DEFNAME = emx.def
TESTNAME= libxmp-test.exe
DLLLITE = libxmplt.dll
DEFLITE = emxlite.def
TESTLITE= libxmp-lite-test.exe

ifeq ($(CROSS),)
CC=gcc
AR=ar
RANLIB=ranlib
else
CC=$(CROSS)-gcc
AR=$(CROSS)-ar
RANLIB=$(CROSS)-ranlib
endif

CFLAGS  = -Iinclude -Wall -O2 -fsigned-char -Zmt
CFLAGS += -DHAVE_FNMATCH -DHAVE_MKSTEMP -DHAVE_UMASK -DHAVE_DIRENT
#CFLAGS += -DDEBUG
LDFLAGS = -Zdll -Zomf -Zmt

ifeq ($(USE_PROWIZARD),0)
CFLAGS += -DLIBXMP_NO_PROWIZARD
endif
ifeq ($(USE_DEPACKERS),0)
CFLAGS += -DLIBXMP_NO_DEPACKERS
else
CFLAGS += -DHAVE_POPEN -DHAVE_FORK -DHAVE_PIPE -DHAVE_EXECVP -DHAVE_DUP2 -DHAVE_WAIT
endif

